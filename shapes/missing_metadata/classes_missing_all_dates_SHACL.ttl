@prefix :         <https://www.tib.eu/digitrubber/shapes#> .
@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix oboInOwl: <http://www.geneontology.org/formats/oboInOwl#> .
@prefix pav:      <http://purl.org/pav/> .

:ClassMissingCreationAndUpdateDateShape
    a sh:NodeShape ;
    sh:severity sh:Violation ;
    
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            SELECT ?this WHERE {
              ?this rdf:type owl:Class .
              FILTER (STRSTARTS(STR(?this), "http://purl.obolibrary.org/obo/") || STRSTARTS(STR(?this), "https://w3id.org/pmd/co/") || STRSTARTS(STR(?this), "http://purl.allotrope.org/ontologies/") || STRSTARTS(STR(?this), "http://ncicb.nci.nih.gov/xml/owl/EVS/"))
            }
        """ ;
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Class '{$classId}' ('{$label}') is missing BOTH oboInOwl:creation_date and pav:lastUpdateOn." ;
        sh:select """
            SELECT ?this ?label
                   (REPLACE(STR(?this), ".*/", "") AS ?classId)
            WHERE {
              
              OPTIONAL { 
  ?this rdfs:label ?labelRaw .
  FILTER ( LANG(?labelRaw) = "en" || LANG(?labelRaw) = "" )
}

BIND(COALESCE(?labelRaw, "NO_LABEL") AS ?label)

              FILTER NOT EXISTS { ?this oboInOwl:creation_date ?creationDate }

              FILTER NOT EXISTS { ?this pav:lastUpdateOn ?lastUpdateOn }
            }
        """ ;
    ] .

    