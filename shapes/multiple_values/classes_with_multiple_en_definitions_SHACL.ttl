@prefix : <https://www.tib.eu/digitrubber/shapes#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .

:ClassMoreThanOneEnglishDefinition
    a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:severity sh:Violation ;

    sh:sparql [
        a sh:SPARQLConstraint ;

        sh:message "Class has more than one English definition." ;

        sh:select """
            SELECT ?this (COUNT(?def) AS ?count)
            WHERE {

              {
                { ?this obo:IAO_0000115 ?def }
                UNION
                { ?this <http://www.w3.org/2004/02/skos/core#definition> ?def }
              }

              FILTER (
                LANGMATCHES(LANG(?def), "en") ||
                LANG(?def) = "co" ||
                LANG(?def) = ""
              )

            }
            GROUP BY ?this
            HAVING (COUNT(?def) > 1)
        """ ;
    ] .